import Config

# Noise protocol keypair for this node (base64-encoded).
# Copy this file to config/secret.exs and fill in the values.
# Generate a keypair with your preferred Noise tooling or via cyrene.
config :zfs_snapcon, Snapcon.TcpServer,
  k_pub:  "base64-encoded-local-public-key",
  k_priv: "base64-encoded-local-private-key",
  c_pub:  "base64-encoded-remote-public-key"
